# Variáveis de ambiente — gestaleadflow-pro
# Copie este arquivo para .env.local e preencha os valores reais

# URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"

# Chave pública (anon key) do Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# Chave de service_role — NUNCA exponha no frontend!
# Usada apenas em Server Actions e API Routes
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# E-mails autorizados a acessar o painel admin (separe por vírgula)
# Exemplo: "admin@suaempresa.com,backup@suaempresa.com"
ADMIN_EMAILS="seu@email.com"
